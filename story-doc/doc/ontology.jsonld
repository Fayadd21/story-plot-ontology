  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Two characters that are openly hostile to each other."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://purl.org/story/social/Character"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "sworn enemy of"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://purl.org/story/social/Character"
  } ]
}, {
  "@id" : "http://purl.org/story/time/StoryTimeInstant",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A time instant that marks a punctual event such as a death or a single decisive action."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "story time instant"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/2006/time#Instant"
  } ]
}, {
  "@id" : "http://purl.org/story/time/StoryTimeInterval",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A non-punctual time interval for an event or episode; subclass of time:ProperInterval so OWL-Time Allen relations apply between intervals."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "story time interval"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.w3.org/2006/time#ProperInterval"
  }, {
    "@id" : "_:genid105"
  }, {
    "@id" : "_:genid106"
  } ]
}, {
  "@id" : "http://purl.org/story/time/hasEnd",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#FunctionalProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Allen-style end function Ie: associates each temporal entity with the instant when it ends."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.w3.org/2006/time#TemporalEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has end instant"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2006/time#Instant"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.w3.org/2006/time#hasEnd"
  } ]
}, {
  "@id" : "http://purl.org/story/time/hasStart",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#FunctionalProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Allen-style start function Is: associates each temporal entity with the instant when it starts."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.w3.org/2006/time#TemporalEntity"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "has start instant"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2006/time#Instant"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "http://www.w3.org/2006/time#hasBeginning"
  } ]
}, {
  "@id" : "http://www.w3.org/2006/time#intervalAfter",
  "http://www.w3.org/2002/07/owl#propertyChainAxiom" : [ {
    "@list" : [ {
      "@id" : "http://purl.org/story/time/hasStart"
    }, {
      "@id" : "http://www.w3.org/2006/time#after"
    }, {
      "@id" : "_:genid66"
    } ]
  } ]
}, {
  "@id" : "http://www.w3.org/2006/time#intervalBefore",
  "http://www.w3.org/2002/07/owl#propertyChainAxiom" : [ {
    "@list" : [ {
      "@id" : "http://purl.org/story/time/hasEnd"
    }, {
      "@id" : "http://www.w3.org/2006/time#before"
    }, {
      "@id" : "_:genid70"
    } ]
  } ]
}, {
  "@id" : "https://purl.org/region/rcc8/",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An ontology for the Region Connection Calculus."
  }, {
    "@language" : "en",
    "@value" : "Classes and properties for the narrated structure of a story, such as stories, chapters and climaxes, and how they relate to events."
  }, {
    "@language" : "en",
    "@value" : "Events with their participants, locations and temporal ordering, using the W3C Time ontology to describe time."
  }, {
    "@language" : "en",
    "@value" : "Intentional doings: agents, patients, instruments, themes; linked to events via sub-event links and participant entailments."
  }, {
    "@language" : "en",
    "@value" : "Non-familial social ties between characters, such as allegiance, enmity or membership in a house or group."
  }, {
    "@language" : "en",
    "@value" : "Places and spatial relations that are relevant for describing a story plot."
  }, {
    "@language" : "en",
    "@value" : "Story intervals use Allen's endpoints Is and Ie via stime:hasStart and stime:hasEnd on top of the W3C Time ontology.\r\n\r\nThe thirteen Allen relations (b, bi, m, mi, o, oi, s, si, d, di, f, fi, eq) are not redefined here: use the corresponding OWL-Time object properties between time:ProperInterval individuals — time:intervalBefore (b), time:intervalAfter (bi), time:intervalMeets (m), time:intervalMetBy (mi), time:intervalOverlaps (o), time:intervalOverlappedBy (oi), time:intervalStarts (s), time:intervalStartedBy (si), time:intervalDuring (d), time:intervalContains (di), time:intervalFinishes (f), time:intervalFinishedBy (fi), time:intervalEquals (eq).\r\n\r\ntime:intervalOverlaps (Allen o) is not symmetric: the inverse is time:intervalOverlappedBy (oi). Do not model story 'overlaps' as a symmetric relation.\r\n\r\nstime:StoryTimeInterval is a proper interval so those relations (domain/range ProperInterval in OWL Time) apply when asserting temporal structure between story intervals. Below, sound property chains link endpoint ordering (time:before / time:after on instants) to intervalBefore / intervalAfter."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Actions in story plots"
  }, {
    "@language" : "en",
    "@value" : "Allen-style time for story plots"
  }, {
    "@language" : "en",
    "@value" : "Events and temporal relations in stories"
  }, {
    "@language" : "en",
    "@value" : "Locations for story plots"
  }, {
    "@language" : "en",
    "@value" : "Narrative structure of stories"
  }, {
    "@language" : "en",
    "@value" : "Social relations in stories"
  }, {
    "@value" : "The RCC8 ontology"
  } ],
  "http://www.w3.org/2002/07/owl#imports" : [ {
    "@id" : "http://purl.org/family/"
  }, {
    "@id" : "http://purl.org/meo/"
  }, {
    "@id" : "http://purl.org/story/event/"
  }, {
    "@id" : "http://purl.org/story/location/"
  }, {
    "@id" : "http://purl.org/story/social/"
  }, {
    "@id" : "http://www.w3.org/2006/time#"
  }, {
    "@id" : "https://purl.org/region/rcc8/"
  } ]
}, {
  "@id" : "https://purl.org/region/rcc8/Region",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A continuous extent of space. Mathematically, given a topological space, this concepts corresponds to a compact subspace with finite diameter."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "region"
  } ]
}, {
  "@id" : "https://purl.org/region/rcc8/dc",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#SymmetricProperty", "http://www.w3.org/2002/07/owl#IrreflexiveProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "The two regions are completely disconnected (there are no common pieces)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://purl.org/region/rcc8/Region"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "disconnected"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://purl.org/region/rcc8/Region"
  } ]
}, {
  "@id" : "https://purl.org/region/rcc8/ec",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#SymmetricProperty", "http://www.w3.org/2002/07/owl#IrreflexiveProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "the boundaries of the regions touch, but their interiors are disjoint"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://purl.org/region/rcc8/Region"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "externally connected"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://purl.org/region/rcc8/Region"
  } ]
}, {
  "@id" : "https://purl.org/region/rcc8/eq",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#SymmetricProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "two regions have the same spatial extent"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://purl.org/region/rcc8/Region"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "equal"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://purl.org/region/rcc8/Region"
  } ]
}, {
  "@id" : "https://purl.org/region/rcc8/ntpp",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#AsymmetricProperty", "http://www.w3.org/2002/07/owl#IrreflexiveProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "the first region is entirely inside the second region and their boundaries do not touch"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://purl.org/region/rcc8/Region"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "non-tangential proper part"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://purl.org/region/rcc8/Region"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://purl.org/region/rcc8/ntppi"
  } ]
}, {
  "@id" : "https://purl.org/region/rcc8/ntppi",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#AsymmetricProperty", "http://www.w3.org/2002/07/owl#IrreflexiveProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "the first region entirely contains the second region and their boundaries do not touch"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://purl.org/region/rcc8/Region"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "non-tangential proper part inverse"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://purl.org/region/rcc8/Region"
  } ]
}, {
  "@id" : "https://purl.org/region/rcc8/po",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#SymmetricProperty", "http://www.w3.org/2002/07/owl#IrreflexiveProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "the two regions partially overlap (there are disjoint sub parts, and some part of one is included in some part of the other"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://purl.org/region/rcc8/Region"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "partially overlapping"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://purl.org/region/rcc8/Region"
  } ]
}, {
  "@id" : "https://purl.org/region/rcc8/tpp",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#AsymmetricProperty", "http://www.w3.org/2002/07/owl#IrreflexiveProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "the first region is entirely inside the second region and their boundaries touch each other from the inside"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://purl.org/region/rcc8/Region"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "tangential proper part"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://purl.org/region/rcc8/Region"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "https://purl.org/region/rcc8/tppi"
  } ]
}, {
  "@id" : "https://purl.org/region/rcc8/tppi",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty", "http://www.w3.org/2002/07/owl#AsymmetricProperty", "http://www.w3.org/2002/07/owl#IrreflexiveProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "the first region entirely contains the second region and their boundaries touch each other from the inside"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "https://purl.org/region/rcc8/Region"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "tangential proper part inverse"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "https://purl.org/region/rcc8/Region"
  } ]
} ]