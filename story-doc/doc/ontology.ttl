                                     rdfs:comment "A named division of a written story, usually corresponding to one or more scenes."@en ;
                                     rdfs:label "chapter"@en .


###  http://purl.org/story/plot/Climax
<http://purl.org/story/plot/Climax> rdf:type owl:Class ;
                                    rdfs:subClassOf <http://purl.org/story/plot/NarrativeUnit> ;
                                    rdfs:comment "A narrative unit that marks the peak of the central conflict of the story."@en ;
                                    rdfs:label "climax"@en .


###  http://purl.org/story/plot/NarrativeUnit
<http://purl.org/story/plot/NarrativeUnit> rdf:type owl:Class ;
                                           rdfs:comment "A self-contained part of a story such as a chapter, scene or episode (chapter titles in the Narn, or shorter scenes inside them)."@en ;
                                           rdfs:label "narrative unit"@en .


###  http://purl.org/story/plot/Story
<http://purl.org/story/plot/Story> rdf:type owl:Class ;
                                   rdfs:comment "A complete narrative work, for example a tale, book or saga. In this assignment the main example is the Narn i Chîn Húrin."@en ;
                                   rdfs:label "story"@en .


###  http://purl.org/story/plot/TragicEnding
<http://purl.org/story/plot/TragicEnding> rdf:type owl:Class ;
                                          rdfs:subClassOf <http://purl.org/story/plot/NarrativeUnit> ;
                                          rdfs:comment "A narrative unit where the main tragic outcome of the story occurs (for the Narn this can be linked to Túrin's death)."@en ;
                                          rdfs:label "tragic ending"@en .


###  http://purl.org/story/social/Character
<http://purl.org/story/social/Character> rdf:type owl:Class ;
                                         rdfs:comment "An individual that can act, speak or simply be mentioned in the story world (for the Narn: people like Túrin, Húrin, Morwen, but also dragons or Valar if needed)."@en ;
                                         rdfs:label "character"@en .


###  http://purl.org/story/social/House
<http://purl.org/story/social/House> rdf:type owl:Class ;
                                     rdfs:comment "A named social group or lineage, such as a house, clan, order or company (e.g. the House of Hador in the Narn)."@en ;
                                     rdfs:label "house or clan"@en .


###  http://purl.org/story/social/Lord
<http://purl.org/story/social/Lord> rdf:type owl:Class ;
                                    rdfs:subClassOf <http://purl.org/story/social/Character> ;
                                    rdfs:comment "A character recognised as lord over others, usually with vassals or followers."@en ;
                                    rdfs:label "lord"@en .


###  http://purl.org/story/social/Occupation
<http://purl.org/story/social/Occupation> rdf:type owl:Class ;
                                          rdfs:subClassOf <http://purl.org/story/social/SocialRole> ;
                                          rdfs:comment "Trade, craft, or habitual work (farmer, smith, thief, etc.); use as object of hasOccupation or hasSocialRole."@en ;
                                          rdfs:label "occupation"@en .


###  http://purl.org/story/social/SocialRole
<http://purl.org/story/social/SocialRole> rdf:type owl:Class ;
                                          rdfs:comment "A social position that a character may hold in the world of the story: lord, captain, messenger, servant, prisoner, and so on."@en ;
                                          rdfs:label "social role"@en .


###  http://purl.org/story/social/Vassal
<http://purl.org/story/social/Vassal> rdf:type owl:Class ;
                                      rdfs:subClassOf <http://purl.org/story/social/Character> ;
                                      rdfs:comment "A character who owes allegiance or service to a lord."@en ;
                                      rdfs:label "vassal"@en .


###  http://purl.org/story/time/StoryTimeInstant
<http://purl.org/story/time/StoryTimeInstant> rdf:type owl:Class ;
                                              rdfs:subClassOf <http://www.w3.org/2006/time#Instant> ;
                                              rdfs:comment "A time instant that marks a punctual event such as a death or a single decisive action."@en ;
                                              rdfs:label "story time instant"@en .


###  http://purl.org/story/time/StoryTimeInterval
<http://purl.org/story/time/StoryTimeInterval> rdf:type owl:Class ;
                                               rdfs:subClassOf <http://www.w3.org/2006/time#ProperInterval> ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <http://purl.org/story/time/hasEnd> ;
                                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                 owl:onClass <http://www.w3.org/2006/time#Instant>
                                                               ] ,
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <http://purl.org/story/time/hasStart> ;
                                                                 owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                                                 owl:onClass <http://www.w3.org/2006/time#Instant>
                                                               ] ;
                                               rdfs:comment "A non-punctual time interval for an event or episode; subclass of time:ProperInterval so OWL-Time Allen relations apply between intervals."@en ;
                                               rdfs:label "story time interval"@en .


###  https://purl.org/region/rcc8/Region
:Region rdf:type owl:Class ;
        rdfs:comment "A continuous extent of space. Mathematically, given a topological space, this concepts corresponds to a compact subspace with finite diameter."@en ;
        rdfs:label "region"@en .


