#################################################################
#    General axioms
#################################################################

[ owl:intersectionOf ( <http://purl.org/story/social/Character>
                       [ rdf:type owl:Restriction ;
                         owl:onProperty <http://purl.org/story/social/hasAllegianceTo> ;
                         owl:someValuesFrom <http://purl.org/story/social/Lord>
                       ]
                     ) ;
  rdf:type owl:Class ;
  rdfs:subClassOf <http://purl.org/story/social/Vassal>
] .


[ rdf:type owl:AllDifferent ;
  owl:distinctMembers ( <http://purl.org/story/social/Blacksmith>
                        <http://purl.org/story/social/Burglar>
                        <http://purl.org/story/social/Farmer>
                        <http://purl.org/story/social/Innkeeper>
                        <http://purl.org/story/social/Merchant>
                        <http://purl.org/story/social/Messenger>
                        <http://purl.org/story/social/Physician>
                        <http://purl.org/story/social/Soldier>
                        <http://purl.org/story/social/Thief>
                      )
] .


[ rdf:type owl:AllDisjointProperties ;
  owl:members ( :dc
                :ec
                :eq
                :ntpp
                :ntppi
                :po
                :tpp
                :tppi
              )
] .


