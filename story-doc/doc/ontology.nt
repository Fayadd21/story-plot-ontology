# http://purl.org/story/action/hasAgent
<http://purl.org/story/action/hasAgent> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://purl.org/story/action/hasAgent> <http://www.w3.org/2000/01/rdf-schema#subPropertyOf> <http://purl.org/story/event/hasParticipant> .
<http://purl.org/story/action/hasAgent> <http://www.w3.org/2000/01/rdf-schema#domain> <http://purl.org/story/action/Action> .
<http://purl.org/story/action/hasAgent> <http://www.w3.org/2000/01/rdf-schema#range> <http://purl.org/story/social/Character> .
<http://purl.org/story/action/hasAgent> <http://www.w3.org/2000/01/rdf-schema#comment> "The character who performs the action on purpose."@en .
<http://purl.org/story/action/hasAgent> <http://www.w3.org/2000/01/rdf-schema#label> "has agent"@en .
# 
# http://purl.org/story/action/hasInstrument
<http://purl.org/story/action/hasInstrument> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://purl.org/story/action/hasInstrument> <http://www.w3.org/2000/01/rdf-schema#subPropertyOf> <http://purl.org/story/event/usesItem> .
<http://purl.org/story/action/hasInstrument> <http://www.w3.org/2000/01/rdf-schema#domain> <http://purl.org/story/action/Action> .
<http://purl.org/story/action/hasInstrument> <http://www.w3.org/2000/01/rdf-schema#comment> "Tool or means used to carry out the action."@en .
<http://purl.org/story/action/hasInstrument> <http://www.w3.org/2000/01/rdf-schema#label> "has instrument"@en .
# 
# http://purl.org/story/action/hasPatient
<http://purl.org/story/action/hasPatient> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://purl.org/story/action/hasPatient> <http://www.w3.org/2000/01/rdf-schema#subPropertyOf> <http://purl.org/story/event/hasParticipant> .
<http://purl.org/story/action/hasPatient> <http://www.w3.org/2000/01/rdf-schema#domain> <http://purl.org/story/action/Action> .
<http://purl.org/story/action/hasPatient> <http://www.w3.org/2000/01/rdf-schema#range> <http://purl.org/story/social/Character> .
<http://purl.org/story/action/hasPatient> <http://www.w3.org/2000/01/rdf-schema#comment> "Character the action is directed at or primarily affects."@en .
<http://purl.org/story/action/hasPatient> <http://www.w3.org/2000/01/rdf-schema#label> "has patient"@en .
# 
# http://purl.org/story/action/hasTheme
<http://purl.org/story/action/hasTheme> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
<http://purl.org/story/action/hasTheme> <http://www.w3.org/2000/01/rdf-schema#domain> <http://purl.org/story/action/Action> .
<http://purl.org/story/action/hasTheme> <http://www.w3.org/2000/01/rdf-schema#range> <http://www.w3.org/2002/07/owl#Thing> .
<http://purl.org/story/action/hasTheme> <http://www.w3.org/2000/01/rdf-schema#comment> "Primary object in view: token given, thing seized, subject of counsel, etc."@en .
<http://purl.org/story/action/hasTheme> <http://www.w3.org/2000/01/rdf-schema#label> "has theme"@en .
# 
# http://purl.org/story/action/subActionOf
<http://purl.org/story/action/subActionOf> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#ObjectProperty> .
